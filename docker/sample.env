# Synapse CTI Deployment Environment
# Copy to .env — deploy.sh populates the provisioning URLs automatically.
#
# DO NOT COMMIT .env to version control (contains one-time-use provisioning secrets).

# ── Synapse version ──────────────────────────────────────────────────────────
# Must be the same for all services. Check https://github.com/vertexproject/synapse/releases
SYNAPSE_VERSION=v2.x.x

# ── AHA identity (IMMUTABLE after first boot) ────────────────────────────────
# AHA_NETWORK becomes the PKI Common Name baked into every service certificate.
# Changing it requires reprovisioning every service from scratch.
AHA_NETWORK=synapsenet

# DNS A record pointing to the Docker host IP.
# Must be resolvable from the Docker host before AHA starts.
# deploy.sh adds this to /etc/hosts on the host automatically.
AHA_DNS_NAME=aha.example.com

# ── Docker host public IP ────────────────────────────────────────────────────
# Set by deploy.sh. Override here if auto-detection is incorrect.
HOST_IP=10.50.49.34

# ── AHA provisioning URLs (populated by deploy.sh — do not edit manually) ───
# These are one-time-use bootstrap tokens generated by AHA.
# Each token expires after a single successful provisioning handshake.
SYN_AXON_AHA_PROVISION=
SYN_JSONSTOR_AHA_PROVISION=
SYN_CORTEX_AHA_PROVISION=

# ── Port assignments ─────────────────────────────────────────────────────────
# Static Telepath (dmon) ports. Changing these after first provisioning
# requires reprovisioning the affected service.
AXON_DMON_PORT=27493
JSONSTOR_DMON_PORT=27494
CORTEX_DMON_PORT=27495
CORTEX_HTTPS_PORT=4443
